# Example environment variables for Labby

# Database — use a managed Postgres in production (Render, Heroku, etc.)
# Example: postgres://dbuser:password@db.example.com:5432/dbname
DATABASE_URL=postgres://<DB_USER>:<DB_PASS>@<DB_HOST>:<DB_PORT>/<DB_NAME>

# Optional: shadow DB used by some migration tools (leave empty if not used)
# SHADOW_DATABASE_URL=postgres://<SHADOW_USER>:<SHADOW_PASS>@<HOST>:<PORT>/<SHADOW_DB>

# App environment
NODE_ENV=production
# PORT is typically provided by the host; set only if required
PORT=3000

# NextAuth (if/when used)
NEXTAUTH_URL=https://your-domain.com
NEXTAUTH_SECRET=<a-long-random-secret>

# SMTP / email settings (used by nodemailer)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=<smtp-user>
SMTP_PASS=<smtp-password>
EMAIL_FROM="Labby <noreply@your-domain.com>"

# Z-AI / agent SDK key (if you use the z-ai-web-dev-sdk)
ZAI_API_KEY=<your_zai_api_key>

# Any other third-party API keys
# EXAMPLE_API_KEY=<value>

# Local development (optional): to use SQLite locally, uncomment this line
# DATABASE_URL=file:./dev.db

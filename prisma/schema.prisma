// Prisma schema for Lab Booking Agent

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String?
  role         String   @default("STUDENT") // STUDENT | FACULTY | STAFF | ADMIN
  department   String?
  createdAt    DateTime @default(now())
  bookings     Booking[]
}

model Lab {
  id          String   @id @default(cuid())
  name        String   @unique
  location    String
  capacity    Int
  description String?
  openTime    String   @default("08:00") // HH:mm 24h
  closeTime   String   @default("22:00") // HH:mm 24h
  status      String   @default("OPEN")  // OPEN | CLOSED | MAINTENANCE
  software    String?  // comma separated software list
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  bookings    Booking[]
}

model Booking {
  id        String   @id @default(cuid())
  userId    String
  labId     String
  date      String   // YYYY-MM-DD
  startTime String   // HH:mm 24h
  endTime   String   // HH:mm 24h
  purpose   String?
  status    String   @default("CONFIRMED") // PENDING | CONFIRMED | CANCELLED | REJECTED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lab       Lab      @relation(fields: [labId], references: [id], onDelete: Cascade)

  @@index([labId, date, status])
  @@index([userId, status])
}
